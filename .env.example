VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Directions: EITHER set a client key here (Phase 2 setup, referrer-restricted)
VITE_GOOGLE_DIRECTIONS_KEY=

# ...OR deploy the supabase/functions/directions Edge Function and flip this on.
# When VITE_USE_EDGE_DIRECTIONS=1 the client calls the Edge Function and the
# key stays server-side. See supabase/functions/directions/README.md.
VITE_USE_EDGE_DIRECTIONS=
